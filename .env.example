# Servidor
PORT=3000
NODE_ENV=development

# Segredo para assinar os JWT de sessao de sala. GERE UM VALOR FORTE e NUNCA comite o real.
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=troque-este-segredo-em-producao
# Tempo de vida do JWT de sessao. Precisa cobrir a duracao esperada de uma
# partida para que reconexoes (F5 / voltar pelo link) funcionem sem re-login.
JWT_EXPIRES_IN=6h

# CORS / origem do frontend
WEB_ORIGIN=http://localhost:5173

# Argon2id (parametros OWASP 2024 como base)
ARGON_MEMORY_KIB=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1
